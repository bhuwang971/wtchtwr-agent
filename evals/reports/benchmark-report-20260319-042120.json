        "sql_text": "SELECT \n    'Highbury' AS portfolio,\n    ROUND(SUM(h.estimated_revenue_30), 2) AS highbury_revenue_30,\n    ROUND(SUM(h.estimated_revenue_60), 2) AS highbury_revenue_60,\n    ROUND(SUM(h.estimated_revenue_90), 2) AS highbury_revenue_90,\n    ROUND(SUM(h.estimated_revenue_365), 2) AS highbury_revenue_365,\n    'Market' AS portfolio,\n    ROUND(SUM(l.estimated_revenue_30), 2) AS market_revenue_30,\n    ROUND(SUM(l.estimated_revenue_60), 2) AS market_revenue_60,\n    ROUND(SUM(l.estimated_revenue_90), 2) AS market_revenue_90,\n    ROUND(SUM(l.estimated_revenue_365), 2) AS market_revenue_365,\n    ROUND(AVG(l.review_scores_rating), 2) AS market_average_rating,\n    COUNT(DISTINCT a.amenity_canonical) AS total_complaints\nFROM \n    highbury_listings h\nJOIN \n    listings_cleaned l ON h.listings_id = l.listings_id\nLEFT JOIN \n    amenities_norm a ON l.listings_id = a.listing_id\nWHERE \n    lower(l.neighbourhood_group) = 'brooklyn' \n    AND lower(h.neighbourhood_group) = 'brooklyn'\n    AND lower(a.amenity_canonical) LIKE '%complain%'\nGROUP BY \n    portfolio;",
